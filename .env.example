# Copy to .env before running anything: cp -f .env.example .env

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Docker host ports (override if 5432/6379 are taken locally)
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/resource_access
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Redis (response cache)
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL_SECONDS=30

# HTTP hardening
CORS_ORIGINS=*
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# Pagination
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# Seeds
SEED_SCALE=1

# Authentication mode: header (x-user-id stub) or jwt (Bearer token)
AUTH_MODE=header
# JWT mode (used when AUTH_MODE=jwt). Provide a JWKS URL in production, or a
# shared secret for local development.
JWT_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_SECRET=

# Observability
# Metrics are scraped from GET /metrics. To send traces to the bundled
# OpenTelemetry Collector (docker compose --profile observability up -d), set
# OTEL_ENABLED=true and OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_SERVICE_NAME=resource-access-api
OTEL_EXPORTER_OTLP_ENDPOINT=

{
  "name": "resource-access-api",
  "version": "1.0.0",
  "private": true,
  "description": "Resource access API with user-scoped visibility, built on NestJS, Drizzle, and PostgreSQL.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --check \"{src,test}/**/*.ts\"",
    "format:write": "prettier --write \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/database/scripts/migrate.ts",
    "db:seed": "tsx src/database/scripts/seed.ts",
    "db:seed:bench": "tsx src/database/scripts/seed-bench.ts",
    "loadtest": "bash scripts/load-test.sh",
    "db:seed:demo": "tsx src/database/scripts/seed-demo.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "drizzle-orm": "0.45.2",
    "helmet": "8.2.0",
    "ioredis": "5.11.1",
    "jose": "6.2.3",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "5.4.0",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.5.0",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@swc/core": "1.15.43",
    "@types/autocannon": "7.12.7",
    "@types/express": "5.0.6",
    "@types/node": "26.0.1",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "autocannon": "8.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.4",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "unplugin-swc": "1.5.9",
    "vitest": "4.1.9"
  }
}
